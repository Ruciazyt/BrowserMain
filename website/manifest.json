{
  "manifest_version": 3,
  "name": "BrowserMain",
  "version": "0.1.0",
  "description": "A retro-futuristic new tab page with LED-matrix aesthetics",
  "permissions": [
    "storage",
    "tabs",
    "bookmarks"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Add Shortcut"
  },
  "chrome_url_overrides": {
    "newTab": "index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}