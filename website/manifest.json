{
  "manifest_version": 3,
  "name": "MyTab",
  "version": "1.0.0",
  "description": "Replace your new tab with a customizable dashboard: search, shortcuts, news, weather, AI chat and more.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "bookmarks"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_title": "Add to MyTab",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Add current page to MyTab"
    },
    "add-shortcut": {
      "suggested_key": {
        "default": "Ctrl+Shift+U",
        "mac": "Command+Shift+U",
        "linux": "Ctrl+Shift+U"
      },
      "description": "Open Add Shortcut dialog"
    },
    "quick-add-shortcut": {
      "suggested_key": {
        "default": "Alt+Shift+A",
        "mac": "Command+Shift+A",
        "linux": "Alt+Shift+A"
      },
      "description": "Quick add current page to MyTab"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
