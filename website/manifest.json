{
  "manifest_version": 3,
  "name": "BrowserMain",
  "version": "0.1.0",
  "description": "A retro-futuristic new tab page with LED-matrix aesthetics",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "tabs",
    "bookmarks",
    "activeTab",
    "identity"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "action": {
    "default_title": "Add to BrowserMain",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      },
      "description": "Add current page to BrowserMain"
    },
    "add-shortcut": {
      "suggested_key": {
        "default": "Command+Shift+U",
        "mac": "Command+Shift+U",
        "linux": "Ctrl+Shift+U"
      },
      "description": "Open Add Shortcut dialog"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
